// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  intern
  admin
}

enum QueryStatus {
  open
  answered
  resolved
  verified
  closed
}

enum FaqSource {
  existing
  crowd_sourced
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  role         UserRole
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  queries Query[]
  replies Reply[]
}

model Query {
  id                 String      @id @default(cuid())
  title              String
  description        String
  category           String
  tags               String[]
  status             QueryStatus @default(open)
  latestReplyPreview String?
  matchedFaqIds      String[]
  verifiedReplyId    String?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  createdBy String
  author    User    @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  replies   Reply[]
}

model Reply {
  id         String   @id @default(cuid())
  body       String
  authorName String
  authorRole UserRole
  isVerified Boolean  @default(false)
  createdAt  DateTime @default(now())

  queryId String
  query   Query  @relation(fields: [queryId], references: [id], onDelete: Cascade)

  authorId String
  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

model FAQ {
  id           String    @id @default(cuid())
  question     String
  answer       String
  category     String
  tags         String[]
  helpfulCount Int       @default(0)
  source       FaqSource @default(crowd_sourced)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}
